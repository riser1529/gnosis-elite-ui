{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "framework": "vite",
  "outputDirectory": "dist/client",
  "routes": [
    {
      "src": "/src/assets/audio.mp3",
      "dest": "/src/assets/audio.mp3"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}