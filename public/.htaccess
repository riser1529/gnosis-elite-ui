# Apache config for LetsHost / cPanel shared hosting
# Place the contents of dist/client/ (including this file) into public_html.

# Enable URL rewriting
RewriteEngine On

# If the request is for a real file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, fall back to index.html (SPA routing)
RewriteRule ^ index.html [L]

# Force HTTPS (optional — uncomment if your domain has an SSL cert)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Correct MIME types
AddType video/mp4 .mp4
AddType audio/mpeg .mp3
AddType image/jpeg .jpg .jpeg
AddType image/png .png
AddType image/svg+xml .svg
AddType application/javascript .js
AddType text/css .css
AddType application/json .json
AddType font/woff2 .woff2
AddType font/woff .woff

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Long-cache hashed assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType video/mp4 "access plus 6 months"
  ExpiresByType audio/mpeg "access plus 6 months"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Allow large file uploads (for hero-video.mp4)
<IfModule mod_headers.c>
  Header set Accept-Ranges bytes
</IfModule>

# Custom error fallback to SPA
ErrorDocument 404 /index.html